{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "KeyEntryCache": {
    "SlidingRetentionPeriod": 30
  },
  "LogCompaction": {
    "CompactionInterval": 60 
  },
  "WriteAheadLog": {
    "Location": "bin/wal"
  },
  "DataStore": {
    "Location": "bin/store"
  },
  "SecondaryCatchUp": {
    "MaxRetryAttempts": 3,
    "BaseRetryDelaySeconds": 1,
    "ReconnectDelaySeconds": 2
  },
  "Cluster": {
    "ElectionTimeoutMs": 5000,
    "HeartbeatIntervalMs": 1500
  }
}
